PORT=3000
BASE_URL=https://yourdomain.com

# Database (Supabase PostgreSQL)
# Get from: Supabase Dashboard > Settings > Database > Connection string > URI
# Use the "Transaction" mode pooler (port 6543) for Vercel serverless:
# postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Cron secret (generate a random string, add to Vercel env vars too)
CRON_SECRET=your_random_secret_here

# Twilio SMS
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
EMAIL_FROM_NAME=Arise Cares Team
EMAIL_FROM_ADDRESS=feedback@arisecares.com

# Google Review
GOOGLE_REVIEW_URL=https://g.page/r/YOUR_PLACE_ID/review

# Internal notifications
INTERNAL_NOTIFY_EMAIL=team@arisecares.com
INTERNAL_NOTIFY_PHONE=+1xxxxxxxxxx

# Feedback thresholds
POSITIVE_THRESHOLD=4
