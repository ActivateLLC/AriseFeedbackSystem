{
  "version": 2,
  "builds": [
    { "src": "src/server.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "src/server.js" }
  ],
  "crons": [
    {
      "path": "/api/cron/process-requests",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/process-followups",
      "schedule": "0 10 * * *"
    }
  ]
}
